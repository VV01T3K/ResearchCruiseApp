FROM oven/bun:1-alpine AS build

ARG APP_ENVIRONMENT="development"
ARG OTEL_SERVICE_NAME="research-cruise-app-frontend"
ARG SENTRY_DSN=""
ARG SENTRY_ENVIRONMENT=""
ARG SENTRY_RELEASE=""
ARG SENTRY_TRACES_SAMPLE_RATE=""
ARG SENTRY_REPLAYS_SESSION_SAMPLE_RATE=""
ARG SENTRY_TUNNEL="/api/sentry-tunnel"
ARG SENTRY_AUTH_TOKEN=""
ARG SENTRY_ORG=""
ARG SENTRY_PROJECT=""

ENV API_URL="/api" \
    APP_ENVIRONMENT=$APP_ENVIRONMENT \
    OTEL_SERVICE_NAME=$OTEL_SERVICE_NAME \
    SENTRY_DSN=$SENTRY_DSN \
    SENTRY_ENVIRONMENT=$SENTRY_ENVIRONMENT \
    SENTRY_RELEASE=$SENTRY_RELEASE \
    SENTRY_TRACES_SAMPLE_RATE=$SENTRY_TRACES_SAMPLE_RATE \
    SENTRY_REPLAYS_SESSION_SAMPLE_RATE=$SENTRY_REPLAYS_SESSION_SAMPLE_RATE \
    SENTRY_TUNNEL=$SENTRY_TUNNEL \
    SENTRY_AUTH_TOKEN=$SENTRY_AUTH_TOKEN \
    SENTRY_ORG=$SENTRY_ORG \
    SENTRY_PROJECT=$SENTRY_PROJECT

WORKDIR /app
COPY package.json bun.lock ./
RUN --mount=type=cache,id=bun,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

COPY . .
RUN bun run build

FROM nginxinc/nginx-unprivileged:1.27-alpine

ARG API_URL="http://backend:8080/"

ENV API_URL=$API_URL

WORKDIR /app
COPY nginx.conf /etc/nginx/templates/default.conf.template
COPY --from=build --chown=nginx:nginx /app/dist /app/

EXPOSE 8080
