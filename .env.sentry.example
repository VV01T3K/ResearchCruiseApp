# Example Sentry configuration for local development.
# Copy to .env.sentry and fill in values from your Sentry project settings.
# Not loaded automatically — wire into frontend build / backend when SDKs are added.

# Frontend (@sentry/react) and/or backend (Sentry.AspNetCore) DSN
SENTRY_DSN=

# Environment name shown in Sentry (local, staging, production)
SENTRY_ENVIRONMENT=local

# Release identifier (git SHA or app version)
SENTRY_RELEASE=

# Performance trace sampling rate (0.0–1.0; use lower values in production)
SENTRY_TRACES_SAMPLE_RATE=1.0

# CI source map / symbol upload (do not commit real tokens)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
