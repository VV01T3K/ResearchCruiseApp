# Local Sentry configuration. The applications provide environment-aware
# defaults for release names, tracing, and replay sampling.
SENTRY_DSN_FRONTEND=
SENTRY_DSN_BACKEND=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=cruiseteam
SENTRY_PROJECT=
