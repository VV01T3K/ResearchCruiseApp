# Example Sentry configuration for local development.
# Copy to .env.sentry and fill in values from your Sentry project settings.
# Wire into docker compose / CI secrets when deploying.

# Shared DSN fallback (backend runtime; optional for frontend if split projects unused)
SENTRY_DSN=

# Split projects (recommended): frontend build-time DSN + backend runtime DSN
# SENTRY_DSN_FRONTEND=
# SENTRY_DSN_BACKEND=

# Environment name shown in Sentry (local, staging, production)
SENTRY_ENVIRONMENT=local

# Release identifier (git SHA or app version)
SENTRY_RELEASE=

# Performance trace sampling rate (0.0–1.0; use lower values in production)
SENTRY_TRACES_SAMPLE_RATE=1.0

# Profiling sampling rate (0.0–1.0; backend only)
SENTRY_PROFILES_SAMPLE_RATE=0

# CI source map / symbol upload (do not commit real tokens)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_PROJECT_FRONTEND=
# SENTRY_PROJECT_BACKEND=
