# Example Sentry configuration for local development.
# Copy to .env.sentry and source before build/run (not loaded automatically).

# Project DSN (frontend build-time + backend runtime)
SENTRY_DSN=

# Environment name shown in Sentry (local, staging, production)
SENTRY_ENVIRONMENT=local

# Release identifier (git SHA or app version; CI often sets GITHUB_SHA)
SENTRY_RELEASE=

# Performance trace sampling (0.0–1.0; use ~0.1–0.2 in production)
SENTRY_TRACES_SAMPLE_RATE=1.0

# Session Replay sampling for normal sessions (errors always replay at 100%)
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.2

# Optional: route SDK traffic via backend to reduce ad-blocker drops
SENTRY_TUNNEL=/api/sentry-tunnel

# Optional: verbose SDK logging in the browser
SENTRY_DEBUG=false

# CI / release builds — source maps (frontend) and debug symbols (backend)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# Backend (ASP.NET Core double-underscore env vars)
# Sentry__Dsn=
# Sentry__Environment=local
# Sentry__TracesSampleRate=1.0
