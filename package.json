{
  "name": "research-cruise-app",
  "private": true,
  "scripts": {
    "dev": "vp run -r dev",
    "build": "vp run --cache -r build",
    "check": "vp run --cache -r check",
    "fix": "vp run --cache -r fix",
    "seed": "vp run -F backend seed",
    "ef:update": "vp run -F backend ef:update",
    "ef:drop": "vp run -F backend ef:drop",
    "ef:migration:add": "vp run -F backend ef:migration:add",
    "ef:migration:remove": "vp run -F backend ef:migration:remove"
  },
  "devDependencies": {
    "lefthook": "^2.1.5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
